# Quins Tracker — environment template. Copy to .env.local and fill in.

# Supabase (NEW project — separate from mykasih-crm)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# GitHub
GITHUB_TOKEN=                 # fine-grained PAT, read-only, build repo
GITHUB_REPO=MyKasih-VA/mykasih
GITHUB_WEBHOOK_SECRET=        # openssl rand -hex 32 — same value as repo secret

# Client share link
CLIENT_SHARE_TOKEN=           # openssl rand -hex 24 — the unguessable token for the client
